# ── Data ──────────────────────────────────────────────────────────
# Directory for db.json, git mirrors, and release assets
DATA_DIR=./data

# Optional fallback tokens when no account is linked in the UI
GITHUB_TOKEN=
GITLAB_TOKEN=

# ── Alerts (optional) ─────────────────────────────────────────────
# Alerts are configured in the UI (Settings → Alerts) and stored in db.json.
# You need a running Apprise API instance, e.g.:
#   docker run -d --name apprise -p 8000:8000 caronc/apprise:latest
# Then set Apprise API URL to http://localhost:8000 (or http://apprise:8000
# when both containers share a Docker network).
# Auto-fills the Apprise API URL in Settings → Alerts when configured.
APPRISE_API_URL=http://apprise:8000

# Public base URL of this instance (OIDC redirects + redirect_uri).
# Must be the URL browsers use — not a Docker container hostname.
# Example: https://gharchive.example.com
APP_URL=http://localhost:3000

# ── Session ───────────────────────────────────────────────────────
# Required when OIDC is enabled (min 16 chars). Generate e.g.:
#   openssl rand -base64 32
SESSION_SECRET=

# Force Secure cookies (default: true when APP_URL is https://)
#COOKIE_SECURE=false

# ── OIDC / SSO (optional) ─────────────────────────────────────────
# When OIDC_ISSUER and OIDC_CLIENT_ID are set, the app requires SSO.
# When unset, the app uses autologin (admin) and shows a security warning.
#
# Works with Authentik, Keycloak, Authelia, Google, Dex, etc.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Space-separated scopes (default: openid profile email)
#OIDC_SCOPES=openid profile email

# Group name that grants admin access. When set, only members of this
# OIDC group get admin privileges. Requires the OIDC provider to include
# a "groups" claim in the userinfo/id_token response.
#OIDC_ADMIN_GROUP=gharchive-admins

# Override callback URL if it differs from ${APP_URL}/api/auth/callback
#OIDC_REDIRECT_URI=https://gharchive.example.com/api/auth/callback
